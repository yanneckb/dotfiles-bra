[user]
	name = yanneck.buelow
	email = yanneck.buelow@brandung.de
[core]
	excludesfile = /Users/yanneck.buelow/.gitignore_global
	excludefile = /Users/yanneck.buelow/.gitignore_global
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[commit]
	template = /Users/yanneck.buelow/.stCommitMsg
